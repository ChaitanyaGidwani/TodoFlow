
{
  "entities": {
    "Todo": {
      "title": "Todo",
      "type": "object",
      "description": "Represents a single to-do item managed by a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "isDaily": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "streakDays": { "type": "number" },
        "lastCompletedDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "completed", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User personalization settings.",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "teddyVariant": { "type": "string" },
        "teddyColor": { "type": "string" },
        "pattern": { "type": "string", "enum": ["none", "paws", "dots", "stripes"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}/todos/{todoId}": {
      "schema": { "$ref": "#/backend/entities/Todo" },
      "description": "User todos."
    },
    "/users/{userId}/profile/settings": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile settings."
    }
  }
}
