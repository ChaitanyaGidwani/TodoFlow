rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for user silos
    match /users/{userId} {
      // Allow user to read and write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Rules for the todos subcollection
      match /todos/{todoId} {
        // Standard read/update/delete check
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        
        // Explicit create check ensuring the userId field matches the path
        allow create: if request.auth != null && 
          request.auth.uid == userId && 
          request.resource.data.userId == userId;
      }
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}