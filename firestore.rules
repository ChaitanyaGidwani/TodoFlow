rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data silo
    match /users/{userId} {
      // Allow access to the user document itself
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicitly allow access to the todos subcollection and its documents
      match /todos/{todoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Catch-all for any other nested data within the user's silo
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Default deny for everything else to maintain strict security
    match /{path=**} {
      allow read, write: if false;
    }
  }
}