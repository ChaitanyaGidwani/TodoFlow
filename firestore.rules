rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * This ruleset enforces strict ownership. 
     * Users can only read and write data under their own UID path.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Match the user's profile document
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Match the user's todo subcollection
      match /todos/{todoId} {
        // 'read' covers both 'get' (single doc) and 'list' (queries)
        // 'write' covers 'create', 'update', and 'delete'
        allow read, write: if isOwner(userId);
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}