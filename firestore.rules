rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * This ruleset enforces strict ownership using recursive wildcards. 
     * Users have full access to their own data silo under /users/{userId}/...
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Recursive match for all documents under a user's path
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Default deny for anything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}