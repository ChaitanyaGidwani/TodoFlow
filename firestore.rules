rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access THEIR OWN data silo
    match /users/{userId} {
      // Allow user to read and write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Rules for the todos subcollection - strictly scoped to the user
      match /todos/{todoId} {
        // Simplified rule: if you are the user identified in the path, you have full access
        allow read, write, delete, create, update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}