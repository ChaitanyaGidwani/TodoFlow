rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bulletproof recursive rule for user-specific data silos
    // This allows the user to read/write their own document and ALL subcollections/descendants
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for everything else to maintain strict security
    match /{path=**} {
      allow read, write: if false;
    }
  }
}