rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access THEIR OWN data silo
    match /users/{userId} {
      // Allow user to read and write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Rules for the todos subcollection - strictly scoped to the user
      match /todos/{document} {
        // Explicitly allow list and read for collection queries and single doc fetches
        // Explicitly allow write operations (create, update, delete)
        allow list, read, write, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}