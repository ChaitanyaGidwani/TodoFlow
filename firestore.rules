rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES
     * 
     * This ruleset enforces strict ownership. 
     * Users have full access to their own data silo under /users/{userId}.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Match the user profile document and its subcollections
    match /users/{userId} {
      // Allows reading and writing the user's own profile document
      allow read, write: if isOwner(userId);
      
      // Explicitly allow access to the todos subcollection
      match /todos/{todoId} {
        allow read, write: if isOwner(userId);
      }
      
      // Allow recursive access to any other subcollections if needed
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Default deny for everything else to ensure security
    match /{path=**} {
      allow read, write: if false;
    }
  }
}